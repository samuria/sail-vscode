{
  "name": "Appian SAIL",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#3f3f3f",
    "editorLineNumber.foreground": "#333333",
    "editorGutter.background": "#f0f0f0",
    "editor.lineHighlightBackground": "#e7f1ff",
    "editorBracketMatch.background": "#62e30033",
    "editorBracketMatch.border": "#62E300"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": "comment.block.sail",
      "settings": { "foreground": "#50B900" }
    },
    {
      "name": "Strings",
      "scope": "string.quoted.double.sail",
      "settings": { "foreground": "#9269C9" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape.sail",
      "settings": { "foreground": "#9269C9" }
    },
    {
      "name": "Variables (local!, ri!, fv!, etc.)",
      "scope": [
        "variable.other.local.sail",
        "variable.other.local.prefix.sail",
        "variable.parameter.sail",
        "variable.parameter.prefix.sail",
        "variable.parameter.keyword.sail",
        "variable.other.fv.sail",
        "variable.other.fv.prefix.sail",
        "variable.other.process.sail",
        "variable.other.process.prefix.sail",
        "variable.language.save.sail",
        "variable.language.save.prefix.sail"
      ],
      "settings": { "foreground": "#24B0ED" }
    },
    {
      "name": "Functions (a! components)",
      "scope": [
        "support.function.sail",
        "support.function.prefix.sail",
        "support.function.builtin.sail",
        "support.function.system.sail"
      ],
      "settings": { "foreground": "#005BD0" }
    },
    {
      "name": "Functions (fn! and custom calls)",
      "scope": [
        "entity.name.function.sail",
        "entity.name.function.prefix.sail"
      ],
      "settings": { "foreground": "#005BD0" }
    },
    {
      "name": "Rules and constants (rule!, cons!)",
      "scope": [
        "entity.name.function.rule.sail",
        "variable.other.constant.sail",
        "variable.other.constant.prefix.sail",
        "entity.name.function.uuid-rule.sail"
      ],
      "settings": { "foreground": "#FF812B" }
    },
    {
      "name": "Record types and URNs",
      "scope": [
        "support.type.record.sail",
        "support.type.record-field.sail",
        "support.type.record-relationship.sail",
        "support.type.urn.sail",
        "entity.name.tag.sail"
      ],
      "settings": { "foreground": "#FF812B" }
    },
    {
      "name": "Type constructors",
      "scope": "entity.name.type.sail",
      "settings": { "foreground": "#9269C9" }
    },
    {
      "name": "Keywords (true, false, null)",
      "scope": [
        "constant.language.boolean.sail",
        "constant.language.null.sail"
      ],
      "settings": { "foreground": "#999999" }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric.sail",
      "settings": { "foreground": "#005BD0" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator.arithmetic.sail",
        "keyword.operator.comparison.sail",
        "keyword.operator.logical.sail",
        "keyword.operator.range.sail"
      ],
      "settings": { "foreground": "#3f3f3f" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator.comma.sail",
        "punctuation.separator.semicolon.sail",
        "punctuation.paren.open.sail",
        "punctuation.paren.close.sail",
        "punctuation.brace.open.sail",
        "punctuation.brace.close.sail",
        "punctuation.bracket.open.sail",
        "punctuation.bracket.close.sail"
      ],
      "settings": { "foreground": "#3f3f3f" }
    }
  ]
}
