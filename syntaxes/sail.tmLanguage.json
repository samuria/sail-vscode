{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SAIL",
  "scopeName": "source.sail",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#single-quoted-identifiers" },
    { "include": "#record-type-references" },
    { "include": "#record-field-references" },
    { "include": "#urn-references" },
    { "include": "#system-sysrules" },
    { "include": "#system-functions" },
    { "include": "#rule-references" },
    { "include": "#constant-references" },
    { "include": "#variables" },
    { "include": "#function-calls" },
    { "include": "#keywords" },
    { "include": "#literals" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.sail",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sail",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sail",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "single-quoted-identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.sail",
          "match": "'type!\\{[^']*\\}[^']*(?:\\?list)?(?:\\^\\d+)?'"
        },
        {
          "name": "entity.name.tag.sail",
          "match": "'[^']*'"
        }
      ]
    },
    "record-type-references": {
      "patterns": [
        {
          "name": "support.type.record.sail",
          "match": "#\"urn:appian:record-type:v1:[a-f0-9\\-]+\""
        }
      ]
    },
    "record-field-references": {
      "patterns": [
        {
          "name": "support.type.record-field.sail",
          "match": "#\"urn:appian:record-field:v1:[a-f0-9\\-/]+\""
        },
        {
          "name": "support.type.record-relationship.sail",
          "match": "#\"urn:appian:record-relationship:v1:[a-f0-9\\-/]+\""
        }
      ]
    },
    "urn-references": {
      "patterns": [
        {
          "name": "support.type.urn.sail",
          "match": "#\"urn:appian:[a-zA-Z\\-]+:v[0-9]+:[^\"]+\""
        }
      ]
    },
    "system-sysrules": {
      "patterns": [
        {
          "name": "support.function.system.sail",
          "match": "#\"SYSTEM_SYSRULES_[a-zA-Z0-9_]+\""
        }
      ]
    },
    "system-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.sail",
          "match": "(?i)\\ba!(localVariables|save|defaultValue|isNullOrEmpty|isNotNullOrEmpty|refreshVariable|forEach|map|update|flatten|keys|hash|match|when|return|queryEntity|queryRecordType|recordData|queryFilter|sortInfo|pagingInfo|relatedRecordData|aggregationFields|grouping|measure|httpResponse|startProcess|queryLogicalExpression|queryExpression|gridField|cardLayout|columnsLayout|columnLayout|sectionLayout|formLayout|dashboardLayout|headerContentLayout|sideBySideLayout|sideBySideItem|boxLayout|stampField|tagField|tagItem|richTextDisplayField|richTextItem|richTextIcon|richTextImage|richTextHeader|richTextBulletedList|richTextNumberedList|buttonLayout|buttonWidget|buttonArrayLayout|imageField|documentImage|userImage|webImage|linkField|dynamicLink|recordLink|safeLink|processTaskLink|startProcessLink|submitLink|documentDownloadLink|milestoneField|progressBarField|cardChoiceField|textField|paragraphField|integerField|floatingPointField|dateField|dateTimeField|dropdownField|multipleDropdownField|radioButtonField|checkboxField|pickerFieldCustom|pickerFieldRecords|pickerFieldUsers|pickerFieldGroups|userRecordLink|fileUploadField|gridLayout|gridColumn|gridRowLayout|recordActionField|recordActionItem|barChartField|lineChartField|columnChartField|pieChartField|areaChartField|chartSeries|chartReferenceLine|colorSchemeCustom|documentViewerField|webContentField|hierarchyBrowserFieldColumns|hierarchyBrowserFieldTree|orgChartField|videoField|webVideo|horizontalLine|messageBanner|signatureField|barcodeField|calllanguagemodel)\\b"
        },
        {
          "match": "(a!)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "support.function.prefix.sail" },
            "2": { "name": "support.function.sail" },
            "3": { "name": "punctuation.paren.open.sail" }
          }
        },
        {
          "match": "(a!)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "support.function.prefix.sail" },
            "2": { "name": "support.function.sail" }
          }
        }
      ]
    },
    "rule-references": {
      "patterns": [
        {
          "match": "(rule!)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.prefix.sail" },
            "2": { "name": "entity.name.function.rule.sail" }
          }
        },
        {
          "name": "entity.name.function.uuid-rule.sail",
          "match": "#\"_a-[a-f0-9\\-]+_\\d+\""
        }
      ]
    },
    "constant-references": {
      "patterns": [
        {
          "match": "(cons!)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.constant.prefix.sail" },
            "2": { "name": "variable.other.constant.sail" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "(ri!)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "variable.parameter.prefix.sail" },
            "2": { "name": "variable.parameter.sail" }
          }
        },
        {
          "match": "(local!)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "variable.other.local.prefix.sail" },
            "2": { "name": "variable.other.local.sail" }
          }
        },
        {
          "match": "(fv!)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "variable.other.fv.prefix.sail" },
            "2": { "name": "variable.other.fv.sail" }
          }
        },
        {
          "match": "(save!)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "variable.language.save.prefix.sail" },
            "2": { "name": "variable.language.save.sail" }
          }
        },
        {
          "match": "(pv!|pp!|tp!|pm!|ac!|http!|rv!|env!)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "variable.other.process.prefix.sail" },
            "2": { "name": "variable.other.process.sail" }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "(fn!)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.prefix.sail" },
            "2": { "name": "entity.name.function.sail" },
            "3": { "name": "punctuation.paren.open.sail" }
          }
        },
        {
          "match": "(fn!)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.prefix.sail" },
            "2": { "name": "entity.name.function.sail" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.sail" },
            "2": { "name": "punctuation.paren.open.sail" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "variable.parameter.keyword.sail" }
          }
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.sail",
          "match": "(?i)\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.sail",
          "match": "(?i)\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sail",
          "match": "\\b\\d+\\.?\\d*([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sail",
          "match": "<>|>=|<=|>|<|="
        },
        {
          "name": "keyword.operator.arithmetic.sail",
          "match": "[+\\-*/^%]"
        },
        {
          "name": "keyword.operator.logical.sail",
          "match": "&"
        },
        {
          "name": "keyword.operator.range.sail",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.paren.open.sail",
          "match": "\\("
        },
        {
          "name": "punctuation.paren.close.sail",
          "match": "\\)"
        },
        {
          "name": "punctuation.brace.open.sail",
          "match": "\\{"
        },
        {
          "name": "punctuation.brace.close.sail",
          "match": "\\}"
        },
        {
          "name": "punctuation.bracket.open.sail",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.close.sail",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.sail",
          "match": ","
        },
        {
          "name": "punctuation.separator.semicolon.sail",
          "match": ";"
        }
      ]
    }
  }
}
