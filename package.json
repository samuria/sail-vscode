{
  "name": "sail-language",
  "displayName": "SAIL Language Support",
  "description": "Syntax highlighting and formatting for Appian SAIL (.sail) files",
  "version": "0.2.0",
  "publisher": "sail-vscode",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sail-vscode/sail-vscode"
  },
  "keywords": ["sail", "appian", "syntax highlighting", "formatter"],
  "type": "commonjs",
  "engines": {
    "vscode": "^1.75.0"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p tsconfig.test.json && node out-test/test/parser.test.js",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.5.4"
  },
  "categories": ["Programming Languages", "Formatters"],
  "activationEvents": ["onLanguage:sail"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sail",
        "aliases": ["SAIL", "sail", "Appian SAIL"],
        "extensions": [".sail"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sail",
        "scopeName": "source.sail",
        "path": "./syntaxes/sail.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          { "scope": "comment.block.sail", "settings": { "foreground": "#6CC644" } },
          { "scope": "string.quoted.double.sail", "settings": { "foreground": "#B07FD8" } },
          { "scope": "constant.character.escape.sail", "settings": { "foreground": "#B07FD8" } },
          { "scope": ["variable.other.local.sail", "variable.other.local.prefix.sail", "variable.parameter.sail", "variable.parameter.prefix.sail", "variable.parameter.keyword.sail", "variable.other.fv.sail", "variable.other.fv.prefix.sail", "variable.other.process.sail", "variable.other.process.prefix.sail", "variable.language.save.sail", "variable.language.save.prefix.sail"], "settings": { "foreground": "#24B0ED" } },
          { "scope": ["support.function.sail", "support.function.prefix.sail", "support.function.builtin.sail", "support.function.system.sail", "entity.name.function.sail", "entity.name.function.prefix.sail"], "settings": { "foreground": "#3794FF" } },
          { "scope": ["entity.name.function.rule.sail", "variable.other.constant.sail", "variable.other.constant.prefix.sail", "entity.name.function.uuid-rule.sail"], "settings": { "foreground": "#FF9B50" } },
          { "scope": ["support.type.record.sail", "support.type.record-field.sail", "support.type.record-relationship.sail", "support.type.urn.sail", "entity.name.tag.sail"], "settings": { "foreground": "#FF9B50" } },
          { "scope": "entity.name.type.sail", "settings": { "foreground": "#B07FD8" } },
          { "scope": ["constant.language.boolean.sail", "constant.language.null.sail"], "settings": { "foreground": "#AAAAAA" } },
          { "scope": "constant.numeric.sail", "settings": { "foreground": "#3794FF" } }
        ]
      }
    }
  }
}
